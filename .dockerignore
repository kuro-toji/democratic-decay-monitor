# =============================================================================
# Docker Ignore - Exclude unnecessary files from build context
# =============================================================================

# Dependencies
node_modules
server/node_modules
client/node_modules
scripts/node_modules

# Build outputs
dist
server/dist
client/dist

# Development files
.git
.gitignore
.env
.env.*
.env.local
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode
.idea
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Documentation
*.md
!README.md
docs

# Tests
**/*.test.ts
**/*.spec.ts
coverage
*.lcov

# Database files (should be in volumes)
*.db
*.db-journal

# Docker files (not needed in context)
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
.github
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Temporary files
tmp
temp
*.tmp
*.temp
