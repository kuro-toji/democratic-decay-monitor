{
  "name": "democratic-decay-monitor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "server",
    "scripts"
  ],
  "scripts": {
    "dev": "vite",
    "dev:server": "bun --cwd server run dev",
    "dev:all": "bun run dev",
    "build": "tsc -b && vite build",
    "build:server": "bun --cwd server run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "bun --cwd server run db:generate",
    "db:migrate": "bun --cwd server run db:migrate",
    "import:data": "bun run scripts/import-data.ts",
    "import:alerts": "curl -X POST http://localhost:3000/api/alerts/evaluate"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}